# ─── Database ─────────────────────────────────────────────────────────────────
# Using SQLite for local dev — swap to PostgreSQL in production:
# DATABASE_URL="postgresql://user:password@localhost:5432/taskflow"
DATABASE_URL="file:./dev.db"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
